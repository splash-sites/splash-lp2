---
const problemas = [
  { titulo: "Site desatualizado ou inexistente", texto: "quem procura sua empresa no Google não te encontra." },
  { titulo: "Processos manuais", texto: "planilha, WhatsApp e papel fazendo o trabalho de um sistema." },
  { titulo: "Concorrência aparecendo primeiro", texto: "e levando o cliente que era seu." },
  { titulo: "Tempo perdido", texto: "com tarefas repetitivas que um sistema faria sozinho." },
];
const solucoes = [
  { titulo: "Site moderno e otimizado", texto: "construído pra converter visita em cliente e aparecer nas buscas." },
  { titulo: "Sistema sob medida", texto: "feito pro seu processo real, não o contrário." },
  { titulo: "Presença que trabalha por você", texto: "24h, sem depender de sorte no Google." },
  { titulo: "Automação do repetitivo", texto: "sua equipe focando no que realmente importa." },
];
---
<section class="bg-[oklch(97%_0.004_250)] px-6 py-24 md:px-12 md:py-[110px]">
  <div class="mx-auto max-w-[1240px]">
    <div class="mb-16 max-w-[620px]" data-aos="fade-up">
      <span class="text-[13px] font-bold uppercase tracking-[0.08em] text-primary">O problema é real</span>
      <h2 class="mt-3.5 font-display text-[28px] font-bold leading-[1.12] tracking-[-0.02em] text-[oklch(16%_0.02_250)] md:text-[38px]">
        Todo dia sem uma presença digital boa é um dia de vendas na mesa.
      </h2>
    </div>
    <div class="grid grid-cols-1 overflow-hidden rounded-[20px] border border-[oklch(90%_0.006_250)] bg-white shadow-[0_20px_40px_-24px_oklch(20%_0.02_250_/_0.15)] md:grid-cols-2">
      <div class="border-b border-[oklch(92%_0.006_250)] p-8 md:border-b-0 md:border-r md:p-11" data-aos="fade-right">
        <span class="text-[12.5px] font-bold uppercase tracking-[0.06em] text-[oklch(50%_0.01_250)]">O que te trava hoje</span>
        <div class="mt-6 flex flex-col gap-[26px]">
          {problemas.map(p => (
            <div class="flex items-start gap-3.5">
              <span class="mt-[7px] h-2 w-2 flex-none rounded-full bg-[oklch(65%_0.16_30)]"></span>
              <p class="m-0 text-[15.5px] leading-[1.55] text-[oklch(30%_0.01_250)]"><strong class="text-[oklch(18%_0.02_250)]">{p.titulo}</strong> — {p.texto}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-[oklch(98.5%_0.006_258)] p-8 md:p-11" data-aos="fade-left">
        <span class="text-[12.5px] font-bold uppercase tracking-[0.06em] text-primary">O que a Splash entrega</span>
        <div class="mt-6 flex flex-col gap-[26px]">
          {solucoes.map(s => (
            <div class="flex items-start gap-3.5">
              <span class="mt-[7px] h-2 w-2 flex-none rounded-full bg-primary"></span>
              <p class="m-0 text-[15.5px] leading-[1.55] text-[oklch(30%_0.01_250)]"><strong class="text-[oklch(18%_0.02_250)]">{s.titulo}</strong> — {s.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
