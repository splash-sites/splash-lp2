<section id="codigo" class="relative overflow-hidden bg-[oklch(15%_0.018_258)] px-6 py-20 md:px-12 md:py-[120px]">
  <div class="pointer-events-none absolute -right-24 -top-24 h-[400px] w-[400px] rounded-full bg-[oklch(56%_0.19_258_/_0.12)]"></div>
  <div class="relative z-10 mx-auto grid max-w-[1240px] grid-cols-1 items-center gap-16 md:grid-cols-[0.9fr_1.1fr]">
    <div data-aos="fade-right">
      <span class="text-[13px] font-bold uppercase tracking-[0.08em] text-[oklch(70%_0.16_258)]">Por trás do código</span>
      <h2 class="my-3.5 font-display text-[28px] font-bold tracking-[-0.02em] text-white md:text-[36px]">Bonito por fora, sólido por dentro.</h2>
      <div class="mt-6 flex flex-col gap-[22px]">
        <div class="flex items-start gap-3.5">
          <div class="flex h-[34px] w-[34px] flex-none items-center justify-center rounded-[9px] bg-[oklch(56%_0.19_258_/_0.18)]">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="oklch(72% 0.16 258)" stroke-width="1.8"/><path d="M20 20l-4-4" stroke="oklch(72% 0.16 258)" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <p class="m-0 text-[15px] leading-[1.6] text-[oklch(82%_0.01_250)]"><strong class="text-white">SEO desde a estrutura</strong> — o código já nasce pensado pra ser encontrado no Google, não como ajuste de última hora.</p>
        </div>
        <div class="flex items-start gap-3.5">
          <div class="flex h-[34px] w-[34px] flex-none items-center justify-center rounded-[9px] bg-[oklch(56%_0.19_258_/_0.18)]">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M4 12l4-4M4 12l4 4M20 12l-4-4M20 12l-4 4" stroke="oklch(72% 0.16 258)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <p class="m-0 text-[15px] leading-[1.6] text-[oklch(82%_0.01_250)]"><strong class="text-white">Stack escolhida pra cada projeto</strong> — nada de solução tamanho único; a tecnologia é decidida pelo problema que você tem.</p>
        </div>
        <div class="flex items-start gap-3.5">
          <div class="flex h-[34px] w-[34px] flex-none items-center justify-center rounded-[9px] bg-[oklch(56%_0.19_258_/_0.18)]">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z" stroke="oklch(72% 0.16 258)" stroke-width="1.6" stroke-linejoin="round"/></svg>
          </div>
          <p class="m-0 text-[15px] leading-[1.6] text-[oklch(82%_0.01_250)]"><strong class="text-white">Performance real</strong> — carregamento rápido em qualquer conexão, porque site lento perde cliente.</p>
        </div>
      </div>
    </div>
    <div class="overflow-hidden rounded-2xl border border-[oklch(28%_0.02_258)] bg-[oklch(12%_0.014_258)] shadow-[0_30px_60px_-20px_oklch(0%_0_0_/_0.5)]" data-aos="fade-left">
      <div class="flex items-center gap-[7px] border-b border-[oklch(24%_0.018_258)] px-[18px] py-[14px]">
        <span class="h-[9px] w-[9px] rounded-full bg-[oklch(58%_0.14_30)]"></span>
        <span class="h-[9px] w-[9px] rounded-full bg-[oklch(65%_0.13_90)]"></span>
        <span class="h-[9px] w-[9px] rounded-full bg-[oklch(60%_0.14_145)]"></span>
        <span class="ml-2.5 font-mono text-[11.5px] text-[oklch(55%_0.01_258)]">seo-config.ts</span>
      </div>
      <div class="p-7 font-mono text-[13.5px] leading-[2] md:px-[30px]">
        <div><span class="text-[oklch(65%_0.14_300)]">export const</span> <span class="text-[oklch(75%_0.14_200)]">metadata</span> <span class="text-[oklch(78%_0.01_258)]">= {'{'}</span></div>
        <div class="pl-5"><span class="text-[oklch(78%_0.1_145)]">title:</span> <span class="text-[oklch(75%_0.13_90)]">'SuaEmpresa · Serviço Principal'</span><span class="text-[oklch(78%_0.01_258)]">,</span></div>
        <div class="pl-5"><span class="text-[oklch(78%_0.1_145)]">description:</span> <span class="text-[oklch(75%_0.13_90)]">'Otimizado para conversão e busca'</span><span class="text-[oklch(78%_0.01_258)]">,</span></div>
        <div class="pl-5"><span class="text-[oklch(78%_0.1_145)]">performance:</span> <span class="text-[oklch(70%_0.16_258)]">'first-paint &lt; 1s'</span><span class="text-[oklch(78%_0.01_258)]">,</span></div>
        <div class="pl-5"><span class="text-[oklch(78%_0.1_145)]">stack:</span> <span class="text-[oklch(78%_0.01_258)]">chosenFor(</span><span class="text-[oklch(75%_0.13_90)]">project</span><span class="text-[oklch(78%_0.01_258)]">),</span></div>
        <div><span class="text-[oklch(78%_0.01_258)]">{'}'}</span><span class="animate-blink ml-1 inline-block h-4 w-2 align-middle bg-[oklch(70%_0.16_258)]"></span></div>
      </div>
    </div>
  </div>
</section>
