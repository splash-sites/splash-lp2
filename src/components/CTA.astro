---
const WHATSAPP = "555182135882";
---
<section class="relative overflow-hidden px-6 py-20 md:px-12 md:py-[110px]">
  <div class="relative mx-auto max-w-[1240px] overflow-hidden rounded-[28px] bg-gradient-to-br from-[oklch(20%_0.03_258)] to-[oklch(30%_0.08_258)] px-8 py-16 text-center md:px-16 md:py-20" data-aos="zoom-in">
    <div class="absolute -left-[60px] -top-[60px] h-[220px] w-[220px] -rotate-[20deg] rounded-[50%_50%_50%_8px] bg-[oklch(56%_0.19_258_/_0.25)]"></div>
    <div class="absolute -bottom-[70px] -right-10 h-[260px] w-[260px] rotate-[160deg] rounded-[50%_50%_50%_8px] bg-[oklch(56%_0.19_258_/_0.16)]"></div>
    <div class="relative z-10">
      <h2 class="mx-auto mb-[18px] max-w-[640px] font-display text-[28px] font-bold tracking-[-0.02em] text-white md:text-[40px]">Bora tirar seu projeto do papel?</h2>
      <p class="mb-9 text-base text-[oklch(80%_0.01_250)] md:text-[16.5px]">Manda uma mensagem — é rápido e sem compromisso.</p>
      <a
        href={`https://wa.me/${WHATSAPP}`}
        class="hover-cta-light inline-flex items-center gap-[10px] rounded-xl bg-white px-8 py-[17px] text-base font-bold text-[oklch(20%_0.02_250)] shadow-[0_16px_32px_-8px_oklch(0%_0_0_/_0.35)] transition-all"
      >
        Chamar no WhatsApp
      </a>
    </div>
  </div>
</section>
