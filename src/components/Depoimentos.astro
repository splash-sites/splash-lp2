---
const depoimentos = [
  { texto: "A gente não aparecia no Google de jeito nenhum. Em três meses de site novo, os agendamentos pelo WhatsApp triplicaram.", nome: "Camila Rezende", cargo: "Dona, clínica odontológica", iniciais: "CR" },
  { texto: "Trocamos a planilha de pedidos por um sistema próprio. O que tomava horas do dia virou questão de minutos.", nome: "Rodrigo Almeida", cargo: "Sócio, distribuidora", iniciais: "RA" },
  { texto: "Nosso portfólio vivia só no Instagram. Hoje o site fecha reunião sozinho antes da gente nem responder a mensagem.", nome: "Juliana Prado", cargo: "Arquiteta, estúdio de arquitetura", iniciais: "JP" },
  { texto: "Cansamos de aluno perguntando horário no direct. Colocamos tudo no site e o número de matrículas por WhatsApp praticamente dobrou.", nome: "Fernanda Costa", cargo: "Gestora, studio de pilates", iniciais: "FC" },
  { texto: "Cardápio, reserva e localização tudo num lugar só. Parou de gente ligando pra perguntar se a gente ainda existia.", nome: "Marcelo Teixeira", cargo: "Proprietário, restaurante", iniciais: "MT" },
];
const slides = [...depoimentos, ...depoimentos.slice(0, 2)];
---
<section class="px-6 py-20 md:px-12 md:py-[120px]">
  <div class="mx-auto max-w-[1240px]">
    <div class="mb-14 max-w-[620px]" data-aos="fade-up">
      <span class="text-[13px] font-bold uppercase tracking-[0.08em] text-primary">Quem confiou</span>
      <h2 class="mt-3.5 font-display text-[28px] font-bold tracking-[-0.02em] text-[oklch(16%_0.02_250)] md:text-[38px]">O que dizem sobre trabalhar com a gente.</h2>
    </div>
    <div class="relative overflow-hidden" data-aos="fade-up" data-carousel>
      <div class="flex" data-track>
        {slides.map((d) => (
          <div class="w-full shrink-0 px-3 md:w-1/3">
            <div class="flex h-full flex-col rounded-2xl border border-[oklch(91%_0.006_250)] bg-[oklch(97%_0.004_250)] p-8">
              <div class="mb-4 text-[22px] tracking-[2px] text-primary">★★★★★</div>
              <p class="mb-6 text-[15px] leading-[1.6] text-[oklch(28%_0.012_250)]">"{d.texto}"</p>
              <div class="mt-auto flex items-center gap-3">
                <div class="flex h-[42px] w-[42px] items-center justify-center rounded-full bg-[oklch(92%_0.03_258)] text-sm font-bold text-[oklch(45%_0.15_258)]">{d.iniciais}</div>
                <div>
                  <div class="text-sm font-bold text-[oklch(18%_0.02_250)]">{d.nome}</div>
                  <div class="text-[12.5px] text-[oklch(50%_0.01_250)]">{d.cargo}</div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
<script>
  const root = document.querySelector<HTMLElement>('[data-carousel]');
  const track = root?.querySelector<HTMLElement>('[data-track]');
  if (root && track) {
    const totalReal = track.children.length - 2;
    let index = 0;

    const slideWidth = () => (track.children[0] as HTMLElement).getBoundingClientRect().width;

    const goTo = (i: number, animate = true) => {
      track.style.transition = animate ? 'transform 0.6s ease' : 'none';
      track.style.transform = `translateX(-${i * slideWidth()}px)`;
    };

    const next = () => {
      index++;
      goTo(index);
      if (index === totalReal) {
        const handler = () => {
          track.removeEventListener('transitionend', handler);
          index = 0;
          goTo(index, false);
        };
        track.addEventListener('transitionend', handler);
      }
    };

    goTo(0, false);
    setInterval(next, 4000);
    window.addEventListener('resize', () => goTo(index, false));
  }
</script>
