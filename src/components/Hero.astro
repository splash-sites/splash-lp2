---
const WHATSAPP = "555182135882";
---
<section class="relative mx-auto grid max-w-[1240px] grid-cols-1 items-center gap-14 px-6 py-16 md:grid-cols-[1.05fr_0.95fr] md:px-12 md:py-24 md:pb-[120px]">
  <div class="pointer-events-none absolute -left-40 -top-32 h-[520px] w-[520px] rounded-full bg-[radial-gradient(circle,oklch(90%_0.05_258_/_0.5),transparent_70%)]"></div>

  <div class="relative z-10 animate-fade-in-up">
    <div class="mb-7 inline-flex items-center gap-2 rounded-full bg-[oklch(94%_0.03_258)] px-3.5 py-[7px] text-[13px] font-bold text-[oklch(45%_0.15_258)]">
      <span class="h-[7px] w-[7px] rounded-full bg-primary"></span>
      Alcance novos clientes
    </div>
    <h1 class="mb-6 max-w-[590px] font-display text-[38px] font-bold leading-[1.06] tracking-[-0.03em] text-[oklch(16%_0.02_250)] md:text-[52px]">
      Enquanto seu site não aparece no Google, seu concorrente está fechando negócio.
    </h1>
    <p class="mb-10 max-w-[500px] text-lg leading-[1.6] text-[oklch(42%_0.012_250)]">
      Criamos landing pages que convertem e sistemas sob medida para pequenas e médias empresas em Torres, RS e região — que tiram o trabalho manual do meio do caminho do seu negócio. Sem gambiarra, sem molde pronto.
    </p>
    <div class="flex flex-wrap items-center gap-5">
      <a
        href={`https://wa.me/${WHATSAPP}`}
        class="hover-cta-primary flex items-center gap-[10px] rounded-xl bg-primary px-7 py-4 text-base font-bold text-white shadow-[0_12px_24px_-8px_oklch(56%_0.19_258_/_0.55)] transition-all"
      >
        Fale com a gente agora
      </a>
    </div>
  </div>

  <div class="relative z-10 animate-fade-in" style="animation-delay:0.3s;">
    <div class="relative rotate-[2.5deg]">
      <div class="overflow-hidden rounded-2xl border border-[oklch(90%_0.006_250)] bg-white shadow-[0_30px_60px_-20px_oklch(20%_0.02_250_/_0.25)]">
        <div class="flex items-center gap-[7px] border-b border-[oklch(93%_0.006_250)] bg-[oklch(97%_0.004_250)] px-[18px] py-[14px]">
          <span class="h-[9px] w-[9px] rounded-full bg-[oklch(75%_0.1_30)]"></span>
          <span class="h-[9px] w-[9px] rounded-full bg-[oklch(80%_0.12_90)]"></span>
          <span class="h-[9px] w-[9px] rounded-full bg-[oklch(75%_0.13_145)]"></span>
          <div class="ml-3.5 rounded-md border border-[oklch(90%_0.006_250)] bg-white px-[30px] py-1 font-mono text-[11px] text-[oklch(55%_0.01_250)]">suaempresa.com.br</div>
        </div>
        <div class="flex flex-col gap-[14px] p-[26px]">
          <div class="flex items-center justify-between">
            <div class="h-[26px] w-[26px] rotate-45 rounded-[50%_50%_50%_4px] bg-primary"></div>
            <div class="flex gap-4">
              <div class="h-2 w-11 rounded bg-[oklch(92%_0.006_250)]"></div>
              <div class="h-2 w-11 rounded bg-[oklch(92%_0.006_250)]"></div>
              <div class="h-2 w-[60px] rounded bg-primary"></div>
            </div>
          </div>
          <div class="flex h-[150px] flex-col justify-center gap-[10px] rounded-[10px] bg-gradient-to-br from-[oklch(96%_0.015_258)] to-[oklch(92%_0.03_258)] p-[22px]">
            <div class="h-[14px] w-[70%] rounded bg-[oklch(30%_0.02_250_/_0.85)]"></div>
            <div class="h-[10px] w-1/2 rounded bg-[oklch(30%_0.02_250_/_0.4)]"></div>
            <div class="mt-1.5 h-[30px] w-[110px] rounded-lg bg-primary"></div>
          </div>
          <div class="grid grid-cols-3 gap-[10px]">
            <div class="h-16 rounded-lg border border-[oklch(92%_0.006_250)] bg-[oklch(96%_0.004_250)]"></div>
            <div class="h-16 rounded-lg border border-[oklch(92%_0.006_250)] bg-[oklch(96%_0.004_250)]"></div>
            <div class="h-16 rounded-lg border border-[oklch(92%_0.006_250)] bg-[oklch(96%_0.004_250)]"></div>
          </div>
        </div>
      </div>
      <div class="animate-float-drop absolute -bottom-[22px] -left-[30px] h-11 w-11 rounded-[50%_50%_50%_6px] bg-gradient-to-br from-[oklch(62%_0.18_250)] to-[oklch(50%_0.2_262)] shadow-[0_14px_24px_-8px_oklch(56%_0.19_258_/_0.5)]"></div>
      <div class="absolute right-[-26px] top-[36%] flex items-center gap-2 rounded-[10px] border border-[oklch(90%_0.006_250)] bg-white px-3.5 py-2.5 shadow-[0_14px_28px_-10px_oklch(20%_0.02_250_/_0.25)]">
        <span class="h-2 w-2 rounded-full bg-[oklch(70%_0.16_145)]"></span>
        <span class="text-[12.5px] font-bold text-[oklch(25%_0.02_250)]">Sistema no ar</span>
      </div>
    </div>
  </div>
</section>
