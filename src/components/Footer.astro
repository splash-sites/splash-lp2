---
const WHATSAPP = "555182135882";
---
<footer class="border-t border-[oklch(90%_0.006_250)] bg-[oklch(97%_0.004_250)] px-6 pb-8 pt-16 md:px-12">
  <div class="mx-auto max-w-[1240px]">
    <div class="grid grid-cols-1 gap-10 border-b border-[oklch(90%_0.006_250)] pb-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="mb-4 flex items-center gap-3">
          <span class="font-display text-lg font-bold text-[oklch(18%_0.02_250)]">Splash Sistemas</span>
        </div>
        <p class="m-0 max-w-[280px] text-sm leading-[1.6] text-[oklch(45%_0.01_250)]">Landing pages que convertem e sistemas sob medida para pequenas e médias empresas.</p>
      </div>
      <div>
        <div class="mb-4 text-[12.5px] font-bold uppercase tracking-[0.05em] text-[oklch(50%_0.01_250)]">Contato</div>
        <div class="flex flex-col gap-[11px]">
          <a href={`https://wa.me/${WHATSAPP}`} class="text-sm text-[oklch(30%_0.01_250)]">(51) 98213-5882</a>
          <a href="mailto:contato@splashsistemas.com.br" class="text-sm text-[oklch(30%_0.01_250)]">contato@splashsistemas.com.br</a>
        </div>
      </div>
      <div>
        <div class="mb-4 text-[12.5px] font-bold uppercase tracking-[0.05em] text-[oklch(50%_0.01_250)]">Redes</div>
        <div class="flex flex-col gap-[11px]">
          <a href="https://www.instagram.com/splash.sistemas/" target="_blank" rel="noopener noreferrer" class="text-sm text-[oklch(30%_0.01_250)]">Instagram</a>
        </div>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-3 pt-7">
      <span class="text-[13px] text-[oklch(55%_0.01_250)]">© 2026 Splash Sistemas. Todos os direitos reservados.</span>
      <span class="text-[13px] text-[oklch(55%_0.01_250)]">Feito com café e código em Torres, RS.</span>
    </div>
  </div>
</footer>
