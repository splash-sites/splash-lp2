---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProblemaSolucao from '../components/ProblemaSolucao.astro';
import Servicos from '../components/Servicos.astro';
// import Portfolio from '../components/Portfolio.astro'; // removida por hora
import Depoimentos from '../components/Depoimentos.astro';
// import Equipe from '../components/Equipe.astro'; // removida por hora
import Codigo from '../components/Codigo.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---
<Layout>
  <div class="w-full overflow-x-clip bg-[oklch(99%_0.002_250)]">
    <Header />
    <Hero />
    <ProblemaSolucao />
    <Servicos />
    <Depoimentos />
    <Codigo />
    <CTA />
    <Footer />
  </div>
  <WhatsAppFloat />
  <script>
    import AOS from 'aos';
    import 'aos/dist/aos.css';
    AOS.init({ duration: 700, once: true, offset: 80 });
  </script>
</Layout>
